{
    "name": "pi0",
    "productName": "pi0",
    "version": "1.1.0",
    "description": "A personal intelligence workbench for macOS — captures your activity, OCRs it on-device into an encrypted local store, and exposes it to AI agents over a local MCP server.",
    "main": ".webpack/main",
    "private": true,
    "scripts": {
        "start": "electron-forge start",
        "package": "electron-forge package",
        "make": "electron-forge make",
        "publish": "electron-forge publish",
        "lint": "eslint --ext .ts,.tsx .",
        "format": "prettier --write . && npm run format:rust",
        "format:check": "prettier --check . && npm run format:rust -- --check",
        "format:rust": "cargo fmt --manifest-path native/Cargo.toml --",
        "build:native": "npm run build --prefix native"
    },
    "keywords": [],
    "author": {
        "name": "Ruiqi Lei",
        "email": "ruiqi.lei25@outlook.com"
    },
    "license": "MIT",
    "devDependencies": {
        "@electron-forge/cli": "^7.11.2",
        "@electron-forge/maker-deb": "^7.11.2",
        "@electron-forge/maker-rpm": "^7.11.2",
        "@electron-forge/maker-squirrel": "^7.11.2",
        "@electron-forge/maker-zip": "^7.11.2",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
        "@electron-forge/plugin-fuses": "^7.11.2",
        "@electron-forge/plugin-webpack": "^7.11.2",
        "@electron/fuses": "^1.8.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "@vercel/webpack-asset-relocator-loader": "^1.7.3",
        "css-loader": "^6.11.0",
        "electron": "43.0.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "fork-ts-checker-webpack-plugin": "^7.3.0",
        "node-loader": "^2.1.0",
        "prettier": "^3.9.4",
        "style-loader": "^3.3.4",
        "ts-loader": "^9.6.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@arco-design/web-react": "^2.66.15",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@pi0/native": "file:native",
        "dayjs": "^1.11.21",
        "electron-squirrel-startup": "^1.0.1",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "zod": "^4.4.3"
    }
}
